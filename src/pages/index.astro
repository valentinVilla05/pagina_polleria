---
import Layout from '@/layouts/Layout.astro'
import CarruselPrincipal from '@/components/blocks/hero-section/carrusel-principal'
import PopularDishes from '@/components/blocks/popular-dishes/popular-dishes'
import Dishes from '@/components/blocks/popular-dishes/carta'
import AboutUs from '@/components/blocks/about-us-section/about-us-page'

// import Testimonials from '@/components/blocks/testimonials-section/testimonials-section'
// import NewItems from '@/components/blocks/new-items-section/new-items'
import ContactUs from '@/components/blocks/contact-us-section/contact-us-page'
import MenusSemanales from '@/components/blocks/offers-section/menus-semanales.tsx'

import { menudata } from '@/assets/data/hero'
import { dishes_ensaladas } from '@/assets/data/ensaladas'
import { dishes_fritos } from '@/assets/data/fritos'
import { popularDishes } from '@/assets/data/popular-dishes'
import { dishes_platos_caseros } from '@/assets/data/platos_caseros'
import { dishes_extras } from '@/assets/data/extras'
import { dishes_postres } from '@/assets/data/postres'
import { stats } from '@/assets/data/about-us'

// import { testimonials } from '@/assets/data/testimonials'
// import { newItems } from '@/assets/data/new-items'
import { contactInfo } from '@/assets/data/contact-us'
import { menusSemanales } from '@/assets/data/offers'

// Page-specific SEO configuration
const pageTitle = 'Asadero Ronda'
const pageDescription = 'Asadero con comida casera para tomar o para llevar.'
const pageKeywords =
  'restaurante, asador, pollo, casero, casera, comida, caliente, postres, a domicilio, Granada, asadero, patatas, raciones, menus, fritos, ensaladas'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Asadero Ronda',
  description: 'Asadero Ronda, comida casera para comer aquí o llevar',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR'
  },
  author: {
    '@type': 'Free Lancer',
    name: 'Valentin Villa Pozo y Daniel Alfonso Vilain'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <CarruselPrincipal menudata={menudata} client:load />
  <PopularDishes popularDishes={popularDishes} client:load />
  <Dishes dishes={dishes_ensaladas} titulo='Ensaladas' client:load />
  <Dishes dishes={dishes_fritos} titulo='Fritos' client:load />
  <Dishes dishes={dishes_platos_caseros} titulo='Platos caseros' client:load />
  <Dishes dishes={dishes_extras} titulo='Extras' client:load />
  <Dishes dishes={dishes_postres} titulo='Postres' client:load />
  <AboutUs stats={stats} />
  <ContactUs contactInfo={contactInfo} />
  <MenusSemanales menu={menusSemanales} />
</Layout>
